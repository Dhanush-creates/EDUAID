# ═══════════════════════════════════════════════════════
# EduAI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Server ──
NODE_ENV=development
PORT=5000

# ── MongoDB (Stage 2) ──
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/eduai?retryWrites=true&w=majority

# ── JWT Auth (Stage 2) ──
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── CORS ──
ALLOWED_ORIGIN=http://localhost:3000

# ── Optional: Email (Stage 2) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@eduai.in
# SMTP_PASS=your_smtp_password
